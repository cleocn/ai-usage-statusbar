{
  "name": "ai-usage-statusbar",
  "displayName": "AI Usage Status Bar",
  "description": "Show GitHub Copilot premium request usage in the VS Code status bar",
  "version": "1.0.0",
  "publisher": "local",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotUsage.refresh",
        "title": "Copilot Usage: Refresh"
      },
      {
        "command": "copilotUsage.signIn",
        "title": "Copilot Usage: Sign in to GitHub"
      },
      {
        "command": "aiUsage.openChatGPTUsage",
        "title": "AI Usage: Open ChatGPT Usage Page"
      },
      {
        "command": "aiUsage.refreshCursor",
        "title": "AI Usage: Refresh Cursor Usage"
      }
    ],
    "configuration": {
      "title": "AI Usage Status Bar",
      "properties": {
        "aiUsage.style": {
          "type": "string",
          "enum": ["minimal", "verbose"],
          "enumDescriptions": ["仅显示图标和数字", "同时显示服务商名称"],
          "default": "minimal",
          "description": "状态栏显示风格"
        },
        "aiUsage.providers.copilot": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏显示 GitHub Copilot 用量"
        },
        "aiUsage.providers.chatgpt": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏显示 ChatGPT 订阅信息"
        },
        "aiUsage.providers.cursor": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏显示 Cursor 用量"
        }
      }
    }
  }
}
